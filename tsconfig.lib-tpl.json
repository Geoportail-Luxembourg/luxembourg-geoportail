{
  "extends": "@vue/tsconfig/tsconfig.web.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": true,
    "strictPropertyInitialization": false,
    "preserveValueImports": false,
    "importsNotUsedAsValues": "remove",
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/lib-tpl/**/*.ts", "src/lib-tpl/**/*.vue", "env.d.ts"],
  "exclude": [
    "src/**/__tests__/*",
    "src/**/*.spec.ts",
    "src/**/*.spec.js",
    "src/components",
    "src/composables",
    "src/services",
    "src/stores",
    "cypress"
  ]
}
