{
  "name": "luxembourg-geoportail",
  "version": "0.0.0-dev",
  "private": true,
  "scripts": {
    "tag": "git tag $(git rev-parse --abbrev-ref HEAD)_DEV_$(git rev-parse --short HEAD)",
    "start": "npm run dev",
    "dev": "vite --force",
    "build": "run-p type-check build-only",
    "build-only": "vite build",
    "build:lib:prod": "npx vite build --mode prod --config vite-dist.config.ts --minify=esbuild --debug && npx babel bundle/lux.dist.mjs --out-file bundle/lux.dist.js",
    "build:lib:dev": "npx vite build --mode staging --config vite-dist.config.ts --minify=false --base=/dev/main.html/ --debug && BABEL_ENV=dev npx babel bundle/lux.dist.mjs --out-file bundle/lux.dist.js",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "dotenv -e .env.e2e -- vitest --environment jsdom --root .",
    "test:unit:ci": "dotenv -e .env.e2e -- vitest run --environment jsdom --coverage",
    "test:e2e": "INSTRUMENT_COVERAGE=true dotenv -e .env.e2e -- start-server-and-test preview :4173 'cypress open --e2e'",
    "test:e2e:ci": "INSTRUMENT_COVERAGE=true dotenv -e .env.e2e -- start-server-and-test 'VITE_USE_PROXYURL=false vite dev --port 4173' http://localhost:4173 'cypress run --browser my-chromium --e2e'",
    "test:e2e:dev": "INSTRUMENT_COVERAGE=true dotenv -e .env.e2e -- start-server-and-test 'vite dev --port 4173' :4173 'cypress open --e2e'",
    "coverage-report": "nyc report",
    "type-check:dev": "npm run type-check -- --watch",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint:js": "eslint . --ext .vue,.js,.cjs,.mjs,.ts,.cts,.mts --ignore-path .prettierignore --quiet",
    "lint:prettier": "prettier --check . --ignore-path .prettierignore",
    "lint": "npm run lint:js && npm run lint:prettier",
    "format": "prettier --write --list-different . --ignore-path .prettierignore && npm run lint:js -- --fix",
    "i18n:migrate:v3-to-app": "node tools/translations/sync-v3-to-app.cjs",
    "i18n:migrate:v3-to-app:dry": "node tools/translations/sync-v3-to-app.cjs --dry-run",
    "i18n:migrate:v3-to-app:prune-client": "node tools/translations/sync-v3-to-app.cjs --prune-client",
    "i18n:migrate:v3-to-app:prune-client:dry": "node tools/translations/sync-v3-to-app.cjs --dry-run --prune-client",
    "i18n:tx:bootstrap:v4-layers": "node tools/translations/bootstrap-v4-layers-from-client-po.cjs",
    "i18n:tx:dedup:client": "node tools/translations/dedup-client-from-layers.cjs",
    "i18n:tx:dedup:client:dry": "node tools/translations/dedup-client-from-layers.cjs --dry-run",
    "i18n:tx:pull": "tx pull -a -t",
    "i18n:tx:transform:v3": "node tools/translations/transform-tx-v3-po-to-v4-json.cjs",
    "i18n:tx:transform:v3:dry": "node tools/translations/transform-tx-v3-po-to-v4-json.cjs --dry-run",
    "i18n:tx:pull:v3-to-v4": "npm run i18n:tx:pull && npm run i18n:tx:transform:v3",
    "i18n:tx:push-app": "tx push -r geoportailv3-lu.geoportailv3-webcomponents -s -t -f",
    "fetch-translations": "tx pull -a -t && node tools/translations/transform-tx-v3-po-to-v4-json.cjs",
    "prepare": "husky install"
  },
  "files": [
    "*",
    "bundle/*"
  ],
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.0",
    "@camptocamp/ogc-client": "^1.2.0",
    "@geoblocks/mapfishprint": "0.2.20",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "luxon": "^3.4.1",
    "mapbox-gl": "^1.7.0",
    "ol": "^10.6.0",
    "pinia": "^2.0.26",
    "sortablejs": "^1.15.2",
    "tailwindcss": "^3.4.4",
    "uuid": "^10.0.0",
    "vue": "^3.2.45",
    "vue-dompurify-html": "^5.3.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.25.7",
    "@babel/core": "^7.25.8",
    "@babel/preset-env": "^7.25.8",
    "@cypress/code-coverage": "^4.0.3",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@pinia/testing": "^0.0.14",
    "@rushstack/eslint-patch": "^1.1.4",
    "@types/d3-array": "^3.2.1",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-selection": "^3.0.10",
    "@types/d3-shape": "^3.1.6",
    "@types/d3-transition": "^3.0.8",
    "@types/d3-zoom": "^3.0.0",
    "@types/google.maps": "^3.58.1",
    "@types/jsdom": "^20.0.1",
    "@types/luxon": "^3.3.1",
    "@types/node": "^22.12.0",
    "@types/proj4": "^2.5.2",
    "@types/sortablejs": "^1.15.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.15",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.2.4",
    "@vue/tsconfig": "^0.1.3",
    "core-js": "^3.37.1",
    "cypress": "^15.13.0",
    "cypress-real-events": "^1.14.0",
    "dotenv-cli": "^7.4.4",
    "eslint": "^8.57.1",
    "eslint-plugin-cypress": "^2.15.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^8.0.2",
    "i18next": "^24.2.2",
    "i18next-http-backend": "^3.0.2",
    "i18next-parser": "^9.0.3",
    "i18next-vue": "^5.2.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.31",
    "prettier": "^3.8.1",
    "proj4": "^2.8.1",
    "start-server-and-test": "^2.1.3",
    "typescript": "~5.4",
    "vite": "^7.3.0",
    "vite-plugin-istanbul": "^7.2.1",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.ts|*.vue": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
